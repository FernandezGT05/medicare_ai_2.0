# Google Sign-In — OAuth 2.0 Web client ID (same value on client and server)
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# PostgreSQL (required)
# Supabase on Vercel: use "Session pooler" URI (host *.pooler.supabase.com) — NOT direct db.*.supabase.co (IPv6)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/medicare

# Beyond Presence API (server only — never expose to the browser)
BEY_API_KEY=

# Catalog agent IDs (optional overrides; defaults are built in)
BEY_AGENT_ID_NELLY=f8efcdd2-2f3f-4fd8-a067-d0376394cabb
BEY_AGENT_ID_YURUO=043a6f54-b04d-49d6-af01-b4ccb5f79359
BEY_AGENT_ID_ALAN=15a39700-f708-4a12-9ab1-eca028d35f5d
BEY_AGENT_ID_JEROME=f373bf15-973b-4075-a0c1-127ab719aac0

# Auth session signing (required — use a long random string in production)
JWT_SECRET=

# OpenAI — visit summaries only (server only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Vercel (optional — set in Project → Settings → Environment Variables)
# FRONTEND_URL=https://your-app.vercel.app
# CLIENT_ORIGIN=https://your-app.vercel.app
# DATABASE_URL=   from Vercel Postgres / Neon integration
# VITE_API_BASE_URL=   leave empty when API is on the same Vercel project (/api)

# Location / nearby places use OpenStreetMap Nominatim (no API key or billing).
